# Copy to .env and fill in the values you need.

# --- LiteLLM ---------------------------------------------------------------
# LiteLLM exposes 100+ providers through a single OpenAI-compatible API.
# Pick *one* of the keys below, depending on which provider you want to use.
LITELLM_MODEL=openai/gpt-4o-mini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHERAI_API_KEY=

# --- Qdrant local store ---------------------------------------------------
QDRANT_PATH=./vectorstore/qdrant

# --- App ------------------------------------------------------------------
# Optional: override which config file FastAPI loads.
# RAG_CONFIG=config/sources.yaml
